-- Tables

create table users (
    usr_id         int not null auto_increment,
    usr_name       varchar(80) not null,              # user name
    usr_email      varchar(120) not null,             # user email
    usr_password   varchar(200) not null,
    usr_gender     char(1) not null,
    usr_age        int not null,
    usr_photo      varchar(255),
    usr_bio        text,
    usr_xp         int not null default 0,            # user xp
    usr_role       enum('admin','normaluser') default 'normaluser',
    usr_created_at datetime not null default current_timestamp,
    primary key (usr_id),
    unique key uq_users_email (usr_email)
);

create table categories (
    cat_id      int not null auto_increment,
    cat_name    varchar(80) not null,
    primary key (cat_id),
    unique key uq_categories_name (cat_name)
);

create table products (
    prd_id           int not null auto_increment,
    prd_name         varchar(120) not null,
    prd_description  text not null,
    prd_cat_id       int not null,                    # FK to categories
    prd_usr_id       int not null,                    # FK to users (seller)
    prd_condition    enum('very good','good', 'satisfactory', 'very used') not null,
    prd_start_price  decimal(10,2) not null,
    prd_location     varchar(120),
    prd_latitude     decimal(10,7),
    prd_longitude    decimal(10,7),
    prd_status       enum('active','ended','sold','expired') default 'active',
    prd_ends_at      datetime not null,
    prd_created_at   datetime not null default current_timestamp,
    primary key (prd_id)
);

create table product_images (
    img_id         int not null auto_increment,
    img_prd_id     int not null,                      # FK to products
    img_path       varchar(255) not null,
    primary key (img_id)
);

create table bids (
    bid_id          int not null auto_increment,
    bid_prd_id      int not null,                     # FK to products
    bid_usr_id      int not null,                     # FK to users
    bid_amount      decimal(10,2) not null,
    bid_created_at  datetime not null default current_timestamp,
    primary key (bid_id),
    index idx_bids_prd_id (bid_prd_id)
);

create table gamification (
    gme_id           int not null auto_increment,
    gme_name         varchar(120) not null,
    gme_description  text,
    gme_xp_reward    int not null,                    # xp reward
    gme_latitude     decimal(10,7) not null,
    gme_longitude    decimal(10,7) not null,
    gme_radius       int not null default 30,
    gme_status       enum('active','expired') default 'active',
    gme_created_at   datetime not null default current_timestamp,
    primary key (gme_id)
);

create table gamification_claims (
    gcl_id           int not null auto_increment,
    gcl_gme_id       int not null,                    # FK to gamification
    gcl_usr_id       int not null,                    # FK to users
    gcl_claimed_at   datetime not null default current_timestamp,
    primary key (gcl_id),
    unique key uq_gamification_user (gcl_gme_id, gcl_usr_id)
);

-- Foreign Keys

alter table products
add constraint products_fk_user
foreign key (prd_usr_id) references users(usr_id)
on delete no action on update no action;

alter table product_images
add constraint product_images_fk_product
foreign key (img_prd_id) references products(prd_id)
on delete cascade on update no action;

alter table products
add constraint products_fk_category
foreign key (prd_cat_id) references categories(cat_id)
on delete no action on update no action;

alter table bids
add constraint bids_fk_product
foreign key (bid_prd_id) references products(prd_id)
on delete cascade on update no action;

alter table bids
add constraint bids_fk_user
foreign key (bid_usr_id) references users(usr_id)
on delete no action on update no action;

alter table gamification_claims
add constraint gamification_claims_fk_gamification
foreign key (gcl_gme_id) references gamification(gme_id)
on delete cascade on update no action;

alter table gamification_claims
add constraint gamification_claims_fk_user
foreign key (gcl_usr_id) references users(usr_id)
on delete cascade on update no action;
